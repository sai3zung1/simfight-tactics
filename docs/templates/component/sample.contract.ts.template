// The values each option can take (its sizes, its variants…). No CSS here.
export const VARIANTS = ["default"] as const;

export const SAMPLE_ELEMENTS = ["div", "span"] as const;

export type SampleVariant = (typeof VARIANTS)[number];
export type SampleElement = (typeof SAMPLE_ELEMENTS)[number];

// The value used when the caller passes none.
export const DEFAULTS = {
  as: "div",
  variant: "default",
} as const satisfies {
  as: SampleElement;
  variant: SampleVariant;
};
