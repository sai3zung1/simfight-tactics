    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.5.2",
    "globals": "^17.6.0",
    "lefthook": "^2.1.6",
    "playwright": "^1.61.1",
    "prettier": "3.8.3",
    "storybook": "^10.5.2",
    "tailwind-csstree": "^0.3.3",
    "tailwindcss": "^4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
